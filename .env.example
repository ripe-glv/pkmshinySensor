# ─────────────────────────────────────────────────────────────
# .env — configuração do Shiny Detector
# Copie para .env: cp .env.example .env
#
# Modo local (padrão): tudo num só PC, não precisa mudar nada.
# Modo lab (2 PCs):    no PC do servidor, descubra o IP com:
#                        ip addr show   (Linux/Mac)
#                        ipconfig       (Windows)
#                      Depois troque SERVER_HOST pelo IP encontrado
#                      e copie o .env para ambos os PCs.
# ─────────────────────────────────────────────────────────────

SERVER_HOST=localhost
UDP_PORT=5000
TCP_PORT=6000
